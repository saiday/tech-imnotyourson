---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Disqus from '../components/Disqus.astro';
import { tagSlug } from '../utils/tags';

export interface Props {
  title: string;
  slug: string;
  description: string;
  date: Date;
  tags: string[];
}

const { title, slug, description, date, tags } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={title} description={description} type="article">
  <link rel="stylesheet" href="https://cdn.rawgit.com/lonekorean/gist-syntax-themes/d49b91b3/stylesheets/idle-fingers.css" />
  <Header />
  <main class="container">
    <article class="post">
      <header class="post-header">
        <h1 class="post-title">{title}</h1>
        <div class="post-meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          {tags.length > 0 && (
            <div class="post-tags">
              {tags.map(tag => (
                <a href={`/tag/${tagSlug(tag)}/`} class="tag">{tag}</a>
              ))}
            </div>
          )}
        </div>
      </header>
      <div class="prose">
        <slot />
      </div>
    </article>
    <Disqus slug={slug} />
  </main>
</BaseLayout>

<style>
  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .post-title {
    font-size: 2rem;
    line-height: 1.2;
    margin: 0 0 0.75rem;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    color: var(--color-accent);
    font-size: 0.8125rem;
  }

  .tag:hover {
    text-decoration: underline;
  }
</style>

<style is:global>
  .prose h2 {
    font-size: 1.5rem;
    margin: 2rem 0 1rem;
  }

  .prose h3 {
    font-size: 1.25rem;
    margin: 1.75rem 0 0.75rem;
  }

  .prose p {
    margin: 0 0 1.25rem;
  }

  .prose a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose a:hover {
    opacity: 0.8;
  }

  .prose pre {
    background-color: #0d1117;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 1rem;
    overflow-x: auto;
    margin: 0 0 1.25rem;
    font-size: 0.875rem;
    line-height: 1.5;
  }

  .prose code {
    font-family: var(--font-mono);
    font-size: 0.875em;
  }

  .prose :not(pre) > code {
    background-color: #2d2d2d;
    padding: 0.15em 0.35em;
    border-radius: 3px;
  }

  .prose blockquote {
    border-left: 3px solid var(--color-border);
    margin: 0 0 1.25rem;
    padding: 0.5rem 1rem;
    color: var(--color-text-muted);
  }

  .prose ul,
  .prose ol {
    margin: 0 0 1.25rem;
    padding-left: 1.5rem;
  }

  .prose li {
    margin-bottom: 0.25rem;
  }

  .prose img {
    border-radius: 6px;
    margin: 1rem 0;
  }

  .prose table {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 1.25rem;
  }

  .prose th,
  .prose td {
    border: 1px solid var(--color-border);
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .prose th {
    background-color: #2d2d2d;
  }

  .prose hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  /* Gist dark theme overrides */
  .gist .gist-file {
    border-color: #30363d;
  }

  .gist .gist-data {
    background-color: #0d1117;
    border-bottom-color: #30363d;
  }

  .gist .gist-meta {
    background-color: #0d1117;
    color: #8b949e;
  }

  .gist .gist-meta a {
    color: #58a6ff;
  }
</style>
