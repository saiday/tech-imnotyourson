<header class="site-header">
  <div class="container">
    <div class="site-branding">
      <a href="/" class="site-title">imnotyourson</a>
      <p class="site-subtitle">Your code and agents are scapegoats; I want you to be nice to it.</p>
    </div>
    <nav class="site-nav">
      <a href="/rss.xml" class="nav-link">RSS</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    padding: 1.5rem 0;
  }

  .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .site-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: #DDDBD9;
    text-decoration: none;
  }

  .site-title:hover {
    text-decoration: none;
    opacity: 0.7;
  }

  .site-branding {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .site-subtitle {
    margin: 0;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .site-nav {
    display: flex;
    gap: 1.5rem;
  }

  .nav-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.875rem;
  }

  .nav-link:hover {
    color: var(--color-text);
    text-decoration: none;
  }
</style>
